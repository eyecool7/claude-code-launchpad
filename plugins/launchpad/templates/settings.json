{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/session-start.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/pre-commit-check.sh"
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/command-guard.sh"
          }
        ]
      },
      {
        "matcher": "mcp__*",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/db-guard.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/edit-monitor.sh"
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/security-trigger.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/secret-guard.sh"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash({{PKG_MANAGER}} run build*)",
      "Bash({{PKG_MANAGER}} run test*)",
      "Bash({{PKG_MANAGER}} test*)",
      "Bash({{PKG_MANAGER}} run lint*)",
      "Bash({{PKG_MANAGER}} run typecheck*)",
      "Bash({{PKG_MANAGER}} run format*)",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(ls *)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(* > .env*)",
      "Bash(* >> .env*)"
    ]
  }
}
